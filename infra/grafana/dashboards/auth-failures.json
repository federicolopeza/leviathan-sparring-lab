{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "uid": "melispy-auth-failures",
  "title": "Melispy \u2014 Auth Failures",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "401/403 Rate \u2014 auth-service",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 8,
        "w": 24
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": ""
          },
          "expr": "sum by (code) (rate({service=\"auth-service\"} | json | status_code=~\"40[13]\" | label_format code=\"{{.status_code}}\" [1m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Top IPs \u2014 Auth Failures (1h)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "h": 8,
        "w": 24
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": ""
          },
          "expr": "topk(10, sum by (client_ip) (count_over_time({service=\"auth-service\"} | json | status_code=~\"40[13]\" [1h])))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Failed Logins Today",
      "gridPos": {
        "x": 0,
        "y": 16,
        "h": 8,
        "w": 24
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": ""
          },
          "expr": "sum(count_over_time({service=\"auth-service\"} |= \"login_failed\" [24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Auth Failures per Minute",
      "gridPos": {
        "x": 0,
        "y": 24,
        "h": 8,
        "w": 24
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": ""
          },
          "expr": "sum(rate({service=\"auth-service\"} | json | status_code=~\"40[13]\" [1m])) * 60"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}

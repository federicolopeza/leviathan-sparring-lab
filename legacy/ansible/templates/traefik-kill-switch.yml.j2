# Leviathan Sparring Lab — Traefik dynamic config for kill-switch
# traefik/dynamic/kill-switch.yml
# Presence of /opt/levlab/KILL_SWITCH file enables operator kill via scripts/kill.sh

http:
  routers:
    kill-switch:
      rule: "Host(`lab.{{ base_domain }}`) && PathPrefix(`/kill-switch`)"
      service: kill-switch-svc
      priority: 10000
      middlewares:
        - kill-switch-headers

  services:
    kill-switch-svc:
      loadBalancer:
        servers: []

  middlewares:
    kill-switch-headers:
      headers:
        customResponseHeaders:
          X-Kill-Switch: "active"
          Content-Type: "application/json"

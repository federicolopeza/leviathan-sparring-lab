## Leviathan Sparring Lab — auditd rules
## /etc/audit/rules.d/99-levlab.rules

# Identity files
-w /etc/passwd -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/sudoers -p wa -k identity
-w /etc/sudoers.d/ -p wa -k identity

# Network config changes
-w /etc/iptables/ -p wa -k network-config
-w /etc/nftables.conf -p wa -k network-config
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k network-config

# Docker binaries + state
-w /usr/bin/docker -p x -k docker-exec
-w /usr/sbin/dockerd -p x -k docker-exec
-w /var/lib/docker -p wa -k docker-state

# cloudflared + wireguard protection
-w /etc/cloudflared/ -p wa -k control-plane
-w /etc/wireguard/ -p wa -k control-plane
-w /usr/local/bin/cloudflared -p x -k control-plane

# SSH config
-w /etc/ssh/sshd_config -p wa -k sshd-config
-w /etc/ssh/sshd_config.d/ -p wa -k sshd-config

# AIDE + rkhunter integrity binaries
-w /usr/bin/aide -p x -k integrity-check
-w /usr/bin/rkhunter -p x -k integrity-check

# Honeytoken watch
-w /etc/levlab-canary/root_token.txt -p rwxa -k levlab-honeytoken
-w /opt/levlab/KILL_SWITCH -p rwa -k kill-switch

# Syscall auditing: execve (b64 + b32)
-a always,exit -F arch=b64 -S execve -k exec
-a always,exit -F arch=b32 -S execve -k exec

# Mount
-a always,exit -F arch=b64 -S mount -k mount

# Module loading
-a always,exit -F arch=b64 -S init_module -S finit_module -k modules

# ptrace
-a always,exit -F arch=b64 -S ptrace -k ptrace

# Make rules immutable (requires reboot to change — disable for benchmark flexibility)
# -e 2
